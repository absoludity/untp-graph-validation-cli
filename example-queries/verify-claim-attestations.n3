@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix untp: <https://test.uncefact.org/vocabulary/untp/> .
@prefix dpp: <https://test.uncefact.org/vocabulary/untp/dpp/0.6.0-beta12/> .
@prefix dcc: <https://test.uncefact.org/vocabulary/untp/dcc/0.6.0-beta12/> .
@prefix vc: <https://www.w3.org/ns/credentials/v2#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .

# This query verifies if claims in DPPs are backed by attestations in DCCs
{
  # Find product passport claims
  ?dppCredential rdf:type dpp:DigitalProductPassport .
  ?dppCredential vc:credentialSubject ?dppSubject .
  ?dppSubject dpp:product ?product .
  ?product dpp:id ?productId .
  ?dppSubject dpp:conformityClaim ?claim .
  ?claim dpp:conformityTopic ?topic .
  ?claim dpp:conformance ?conformance .
  
  # Find conformity evidence link if available
  OPTIONAL {
    ?claim dpp:conformityEvidence ?evidence .
    ?evidence dpp:linkURL ?evidenceLink .
  }
  
  # Find matching conformity credential
  ?dccCredential rdf:type dcc:DigitalConformityCredential .
  ?dccCredential vc:credentialSubject ?dccSubject .
  ?dccSubject dcc:assessment ?assessment .
  ?assessment dcc:assessedProduct ?assessedProduct .
  ?assessedProduct dcc:product ?assessedProductObj .
  ?assessedProductObj dpp:id ?productId .  # Same product ID
  ?assessment dcc:conformityTopic ?topic .  # Same topic
  ?assessment dcc:conformance ?dccConformance .
  
  # Check if conformance values match
  ?conformance log:equalTo ?dccConformance .
  
} => {
  ?product 
    dpp:id ?productId ;
    dpp:hasVerifiedClaim [
      dpp:topic ?topic ;
      dpp:conformance ?conformance ;
      dpp:verifiedBy ?dccCredential
    ] .
}.

# Find claims without matching attestations
{
  # Find product passport claims
  ?dppCredential rdf:type dpp:DigitalProductPassport .
  ?dppCredential vc:credentialSubject ?dppSubject .
  ?dppSubject dpp:product ?product .
  ?product dpp:id ?productId .
  ?product dpp:name ?productName .
  ?dppSubject dpp:conformityClaim ?claim .
  ?claim dpp:conformityTopic ?topic .
  ?claim dpp:conformance ?conformance .
  
  # Check that there is no matching conformity credential
  NOT {
    ?dccCredential rdf:type dcc:DigitalConformityCredential .
    ?dccCredential vc:credentialSubject ?dccSubject .
    ?dccSubject dcc:assessment ?assessment .
    ?assessment dcc:assessedProduct ?assessedProduct .
    ?assessedProduct dcc:product ?assessedProductObj .
    ?assessedProductObj dpp:id ?productId .  # Same product ID
    ?assessment dcc:conformityTopic ?topic .  # Same topic
    ?assessment dcc:conformance ?conformance .  # Same conformance
  }
  
} => {
  ?product 
    dpp:id ?productId ;
    dpp:name ?productName ;
    dpp:hasUnverifiedClaim [
      dpp:topic ?topic ;
      dpp:conformance ?conformance ;
      dpp:warning "No matching attestation found"
    ] .
}.
